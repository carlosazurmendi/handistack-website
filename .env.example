# ============================================================
#  Handistack site — environment template
#  Copy to .env (gitignored) and fill real values.
# ============================================================

# ---- App / Payload ----
PAYLOAD_SECRET=change-me-long-random-string
# Public origin, read at RUNTIME (server-side: metadata, Payload serverURL, n8n callback
# URL). Prefer this over NEXT_PUBLIC_SERVER_URL for Docker since it isn't build-inlined.
APP_URL=https://handistack.com
# Optional build-time public origin (client bundle). Fine to leave as the prod URL.
NEXT_PUBLIC_SERVER_URL=https://handistack.com
# Host that should serve the Payload admin (middleware rewrites this host -> /admin)
ADMIN_HOST=adminportal.handistack.com

# ---- Supabase / Postgres (Payload db adapter) ----
# Use the DIRECT 5432 connection for migrations; pooled 6543 (?pgbouncer=true) for serverless runtimes.
DATABASE_URI=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://PROJECT.supabase.co
# New-style Supabase API keys (not the legacy anon/service_role JWTs)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# ---- Google (service account + domain-wide delegation) ----
# Provide ONE of these two. Path is easiest locally; B64 is the one to use in Docker/VPS
# (no file to mount). Generate B64:  base64 -w0 secrets/google-service-account.json
# GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_B64=base64-of-the-service-account-json
# User the service account impersonates (must own / have edit rights on GOOGLE_CALENDAR_ID)
GOOGLE_IMPERSONATE_SUBJECT=cazurmendi@handistack.com
GOOGLE_CALENDAR_ID=cazurmendi@handistack.com
GOOGLE_TIMEZONE=America/New_York
# Public Google booking page (human-facing "add to calendar" link)
GOOGLE_BOOKING_URL=https://calendar.app.google/z6AfmxQy9sCRz7tx5

# ---- Booking availability window (EST) ----
# Comma-separated HH:MM-HH:MM windows; slots are 30 min inside these, minus busy times.
BOOKING_WINDOWS=09:00-11:00,13:00-15:00
BOOKING_SLOT_MINUTES=30
BOOKING_LEAD_DAYS=0          # earliest bookable day offset from today
BOOKING_HORIZON_DAYS=30      # how far ahead the calendar opens

# ---- Email (Gmail API via the service account) ----
# Mail is sent through the same domain-wide-delegated service account (gmail.send
# scope), as this address. Must be the impersonated user or one of its send-as aliases.
EMAIL_FROM_ADDRESS=cazurmendi@handistack.com
EMAIL_FROM_NAME=Handistack

# ---- Supabase Storage (media uploads, S3-compatible) ----
# Generate S3 access keys in Supabase: Storage -> Settings -> S3 access keys.
# Create a PUBLIC bucket (default name "media"). Leave the keys blank to keep media
# on local disk / the Docker volume instead.
SUPABASE_S3_ENDPOINT=https://PROJECT.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1            # must match your Supabase project region
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=media

# ---- n8n qualification webhook ----
N8N_WEBHOOK_URL=https://n8n.throughthe.cloud/webhook/xxxxxxxx
# n8n Header Auth: the header NAME from your webhook credential + the token VALUE.
# These must match the credential exactly or n8n replies 403 "Authorization data is wrong!".
N8N_WEBHOOK_HEADER=handistack-website
N8N_WEBHOOK_TOKEN=xxxx
# Callback (n8n -> site): the header NAME n8n sends the secret in, + the secret VALUE.
N8N_CALLBACK_HEADER=handistack-website-callback
N8N_CALLBACK_SECRET=xxxx
