    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-s3": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "google-auth-library": "10.6.2",
    "googleapis": "173.0.0",
    "graphql": "16.9.0",
    "next": "16.2.7",
    "payload": "3.85.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.1",
    "dotenv": "16.4.7",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
